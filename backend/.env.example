# ── Stockify Backend — Environment Variables ──────────────────────────────────
# Copy to .env and fill in values

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Database (local dev — ignored if DATABASE_URL is set) ──────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=stockify_db
DB_USER=root
DB_PASS=

# ── Database (Railway — paste directly from Railway dashboard) ─────────────────
# DATABASE_URL=mysql://user:pass@host:port/dbname

# ── Auth ───────────────────────────────────────────────────────────────────────
# IMPORTANT: Use a long random string in production (openssl rand -base64 32)
JWT_SECRET=change_me_to_a_secure_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d

# ── OTP ────────────────────────────────────────────────────────────────────────
OTP_EXPIRES_MINUTES=10

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
FRONTEND_URL=http://localhost:3000
# For production: ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-custom-domain.com
ALLOWED_ORIGINS=http://localhost:3000